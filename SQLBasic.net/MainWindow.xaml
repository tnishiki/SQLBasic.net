<Window x:Class="SQLBasic_net.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:local="clr-namespace:SQLBasic_net"
        mc:Ignorable="d"
        Title="SQLBasic.net" Height="500" Width="1000">
    <Window.Resources>
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#2D2D30"/>
            <!-- トラック部分 -->
            <Setter Property="Foreground" Value="#555"/>
            <!-- グリップ -->
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="Thumb">
            <Setter Property="Background" Value="#555"/>
            <Setter Property="BorderBrush" Value="#777"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>
    <Window.InputBindings>
        <!-- F5 実行 -->
        <KeyBinding Key="F5" Command="{Binding ExecuteCommand}" />
        <!-- F4 新規 -->
        <KeyBinding Key="F4" Command="{Binding ClearCommand}" />
        <!-- Ctrl+O: 開く -->
        <KeyBinding Modifiers="Control" Key="O" Command="{Binding OpenCommand}"/>
        <!-- Ctrl+S: 保存 -->
        <KeyBinding Modifiers="Control" Key="S" Command="{Binding SaveCommand}"/>
        <!-- Alt+C:  色 -->
        <KeyBinding Modifiers="Alt" Key="C" Command="{Binding SetSytaxCommand}"/>
        <!-- Ctrl+L: CSVエキスポート -->
        <KeyBinding Modifiers="Control" Key="L" Command="{Binding CsvExportCommand}"/>
        <!-- Alt+F: 文書全体整形 -->
        <KeyBinding Modifiers="Alt" Key="F" Command="{Binding FormatDocumentCommand}"/>
        <!-- Ctrl+K: 行コメント -->
        <KeyBinding Modifiers="Ctrl" Key="K" Command="{Binding SetCommentCommand}"/>
        <!-- Shift+Ctrl+K: 行コメント解除 -->
        <KeyBinding Modifiers="Ctrl+Shift" Key="K" Command="{Binding RemoveCommentCommand}"/>
    </Window.InputBindings>
    <Grid Background="#1E1E1E">
        <Grid.RowDefinitions>
            <RowDefinition Height="42"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="20"/>
        </Grid.RowDefinitions>
        <ToolBarTray Grid.Row="0" Background="#2D2D30">
            <ToolBar Background="#606060" BorderThickness="0" Padding="10,5">
                <!-- 実行ボタン（強調） -->
                <Button Command="{Binding ExecuteCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="▶" Foreground="#3CB371" FontWeight="Bold"/>
                        <TextBlock Text="{Binding [Btn_Execute_Text], Source={x:Static local:LocalizationManager.Instance}}" Foreground="White"/>
                    </StackPanel>
                </Button>
                <Separator/>
                <!-- ファイル操作系 -->
                <Button Content="{Binding [Btn_New], Source={x:Static local:LocalizationManager.Instance}}" Command="{Binding ClearCommand}" Foreground="White" Margin="2,0" Padding="8,4"/>
                <Button Content="{Binding [Btn_Open], Source={x:Static local:LocalizationManager.Instance}}" Command="{Binding OpenCommand}" Foreground="White" Margin="2,0" Padding="8,4"/>
                <Button Content="{Binding [Btn_Save], Source={x:Static local:LocalizationManager.Instance}}" Command="{Binding SaveCommand}" Foreground="White" Margin="2,0" Padding="8,4"/>
                <Button Content="{Binding [Btn_Export], Source={x:Static local:LocalizationManager.Instance}}" Command="{Binding CsvExportCommand}" Foreground="White" Margin="2,0" Padding="8,4"/>
                <Separator/>
                <!-- 表示設定系 -->
                <Button Content="{Binding [Btn_Color], Source={x:Static local:LocalizationManager.Instance}}" Command="{Binding SetSytaxCommand}" Foreground="White" Margin="2,0" Padding="8,4"/>

                <TextBlock Text="{Binding [Lbl_Font], Source={x:Static local:LocalizationManager.Instance}}" Foreground="White" VerticalAlignment="Center" Margin="10,0,5,0"/>
                <StackPanel Orientation="Horizontal">
                    <Button Content="🔼" Command="{Binding FontToLargeCommand}"  Margin="2,0" Padding="2,2"/>
                    <Button Content="🔽" Command="{Binding FontToSmallCommand}"  Margin="2,0" Padding="2,2"/>
                </StackPanel>
                <Separator/>
                <Button Content="{Binding [Btn_Format], Source={x:Static local:LocalizationManager.Instance}}" Command="{Binding FormatDocumentCommand}" Foreground="White" Margin="2,0" Padding="8,4"/>
                <Button Content="{Binding [Btn_Comment], Source={x:Static local:LocalizationManager.Instance}}" Command="{Binding SetCommentCommand}" Foreground="White" Margin="2,0" Padding="8,4"/>
                <Button Content="{Binding [Btn_Uncomment], Source={x:Static local:LocalizationManager.Instance}}" Command="{Binding RemoveCommentCommand}" Foreground="White" Margin="2,0" Padding="8,4"/>
            </ToolBar>
        </ToolBarTray>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="{Binding EditorRowHeight}"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="{Binding ResultRowHeight}"/>
                    <RowDefinition Height="20"/>
                </Grid.RowDefinitions>
                <avalonEdit:TextEditor
                    x:Name="SqlEditor"
                    Grid.Row="0" Margin="6,3,4,7"
                    Document ="{Binding SqlDocument, Mode=TwoWay}"
                    FontSize="{Binding FontSize}"
                    FontFamily="Consolas"
                    ShowLineNumbers ="True"
                    Foreground="White"
                    Background="{Binding EditorBackground}"
                    SyntaxHighlighting="{Binding SyntaxSet}"/>
                <GridSplitter Grid.Row="1" ResizeDirection="Rows" Height="10" HorizontalAlignment="Stretch" Background="DarkGray"/>
                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="25"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="{Binding [Lbl_Results], Source={x:Static local:LocalizationManager.Instance}}" Foreground="White" VerticalAlignment="Bottom"/>
                    <DataGrid Grid.Row="1" x:Name="QueryGrid" ItemsSource="{Binding GridItems}" HeadersVisibility="Column"
                          Foreground="White" Background="#1E1E1E" BorderBrush="#444" AlternatingRowBackground="#333333"
                          RowBackground="Black"
                          GridLinesVisibility="None"
                          AutoGenerateColumns="False" Margin="5" IsReadOnly="True">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#2D2D30"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="BorderBrush" Value="#444"/>
                                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                    </DataGrid>
                </Grid>
            </Grid>
            <Grid Grid.Column="1" Background="#2D2D30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="35"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="5,0,5,0">
                    <TextBlock Text="{Binding [Lbl_Tables], Source={x:Static local:LocalizationManager.Instance}}" VerticalAlignment="Bottom" Foreground="White"/>
                </Grid>
                <ListBox Grid.Row="1" ItemsSource="{Binding TableNames}" SelectedItem="{Binding SelectedTableName}" Margin="5,0,5,0"/>
                <DataGrid Grid.Row="2" ItemsSource="{Binding ColumnInfos}" HeadersVisibility="Column"
                          Foreground="White" Background="#1E1E1E" BorderBrush="#444" AlternatingRowBackground="#333333"
                          RowBackground="Black"
                          GridLinesVisibility="None"
                          AutoGenerateColumns="False" Margin="5" IsReadOnly="True">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#2D2D30"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="BorderBrush" Value="#444"/>
                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Binding="{Binding Name}">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{Binding [Col_ColumnName], Source={x:Static local:LocalizationManager.Instance}}"/>
                            </DataGridTextColumn.Header>
                        </DataGridTextColumn>
                        <DataGridTextColumn Binding="{Binding DataType}">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{Binding [Col_DataType], Source={x:Static local:LocalizationManager.Instance}}"/>
                            </DataGridTextColumn.Header>
                        </DataGridTextColumn>
                        <DataGridTextColumn Binding="{Binding IsNullable}">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{Binding [Col_Nullable], Source={x:Static local:LocalizationManager.Instance}}"/>
                            </DataGridTextColumn.Header>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
                <Button Grid.Row="3" Content="{Binding [Btn_ConnectDb], Source={x:Static local:LocalizationManager.Instance}}" Command="{Binding ConnectDbCommand}" Margin="5,5,5,5"/>
                <!-- 言語選択 -->
                <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,5,5,5">
                    <TextBlock Text="{Binding [Lbl_Language], Source={x:Static local:LocalizationManager.Instance}}" Foreground="White" VerticalAlignment="Center" Margin="5,0,5,0"/>
                    <ComboBox ItemsSource="{Binding LanguageItems}" SelectedItem="{Binding SelectedLanguage}" DisplayMemberPath="Display" Width="120"/>
                </StackPanel>
            </Grid>
        </Grid>
        <StatusBar Grid.Row="2" Background="#2D2D30" Foreground="White">
            <StatusBarItem Content="{Binding [Lbl_Count], Source={x:Static local:LocalizationManager.Instance}}"/>
            <StatusBarItem Content="{Binding DataNum}"/>
            <StatusBarItem Content="{Binding [Lbl_CountUnit], Source={x:Static local:LocalizationManager.Instance}}"/>
            <Separator/>
            <StatusBarItem Content="{Binding [Lbl_Message], Source={x:Static local:LocalizationManager.Instance}}"/>
            <StatusBarItem Content="{Binding SQLMessage}"/>
        </StatusBar>
    </Grid>
</Window>
