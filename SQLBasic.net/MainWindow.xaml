<Window x:Class="SQLBasic_net.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:local="clr-namespace:SQLBasic_net"
        mc:Ignorable="d"
        Title="SQLBasic.net" Height="600" Width="1100"
        Background="#1E1E1E">

    <Window.InputBindings>
        <!-- F5 実行 -->
        <KeyBinding Key="F5" Command="{Binding ExecuteCommand}" />
        <!-- F4 新規 -->
        <KeyBinding Key="F4" Command="{Binding ClearCommand}" />
        <!-- Ctrl+O: 開く -->
        <KeyBinding Modifiers="Control" Key="O" Command="{Binding OpenCommand}"/>
        <!-- Ctrl+S: 保存 -->
        <KeyBinding Modifiers="Control" Key="S" Command="{Binding SaveCommand}"/>
        <!-- Alt+C:  色 -->
        <KeyBinding Modifiers="Alt" Key="C" Command="{Binding SetSyntaxCommand}"/>
        <!-- Ctrl+L: CSVエキスポート -->
        <KeyBinding Modifiers="Control" Key="L" Command="{Binding CsvExportCommand}"/>
        <!-- Alt+F: 文書全体整形 -->
        <KeyBinding Modifiers="Alt" Key="F" Command="{Binding FormatDocumentCommand}"/>
        <!-- Ctrl+K: 行コメント -->
        <KeyBinding Modifiers="Ctrl" Key="K" Command="{Binding SetCommentCommand}"/>
        <!-- Shift+Ctrl+K: 行コメント解除 -->
        <KeyBinding Modifiers="Ctrl+Shift" Key="K" Command="{Binding RemoveCommentCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3E3E42"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ExecuteButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#2D8857"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="5,2"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3CB371"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="RowBackground" Value="#252526"/>
            <Setter Property="AlternatingRowBackground" Value="#2D2D30"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#333337"/>
            <Setter Property="Foreground" Value="#BBB"/>
            <Setter Property="Padding" Value="5,3"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#444"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="45"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="25"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2D2D30" BorderBrush="#111" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="5,0">
                <Button Style="{StaticResource ExecuteButtonStyle}" Command="{Binding ExecuteCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="▶ " FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding [Btn_Execute_Text], Source={x:Static local:LocalizationManager.Instance}}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Rectangle Width="1" Fill="#444" Margin="10,8"/>

                <Button Content="📄" ToolTip="{Binding [Btn_New], Source={x:Static local:LocalizationManager.Instance}}" Command="{Binding ClearCommand}"/>
                <Button Content="📂" ToolTip="{Binding [Btn_Open], Source={x:Static local:LocalizationManager.Instance}}" Command="{Binding OpenCommand}"/>
                <Button Content="💾" ToolTip="{Binding [Btn_Save], Source={x:Static local:LocalizationManager.Instance}}" Command="{Binding SaveCommand}"/>
                <Button Content="📤" ToolTip="{Binding [Btn_Export], Source={x:Static local:LocalizationManager.Instance}}" Command="{Binding CsvExportCommand}"/>

                <Rectangle Width="1" Fill="#444" Margin="10,8"/>

                <Button Content="🎨" ToolTip="{Binding [Btn_Color], Source={x:Static local:LocalizationManager.Instance}}" Command="{Binding SetSyntaxCommand}"/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                    <Button Content="A+" ToolTip="{Binding [Btn_FontLarge], Source={x:Static local:LocalizationManager.Instance}}" Command="{Binding FontToLargeCommand}" Padding="5,2"/>
                    <Button Content="a-" ToolTip="{Binding [Btn_FontSmall], Source={x:Static local:LocalizationManager.Instance}}" Command="{Binding FontToSmallCommand}" Padding="5,2"/>
                </StackPanel>

                <Rectangle Width="1" Fill="#444" Margin="10,8"/>

                <Button Content="{Binding [Btn_Format], Source={x:Static local:LocalizationManager.Instance}}" ToolTip="{Binding [Btn_Format], Source={x:Static local:LocalizationManager.Instance}}" Command="{Binding FormatDocumentCommand}"/>
                <Button Content="{Binding [Btn_Comment], Source={x:Static local:LocalizationManager.Instance}}" ToolTip="{Binding [Btn_Comment], Source={x:Static local:LocalizationManager.Instance}}" Command="{Binding SetCommentCommand}"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="1*" MinWidth="200"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="3*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="2*"/>
                </Grid.RowDefinitions>

                <avalonEdit:TextEditor x:Name="SqlEditor" Grid.Row="0"
                    Document="{Binding SqlDocument, Mode=TwoWay}"
                    FontSize="{Binding FontSize}"
                    FontFamily="Cascadia Code, Consolas"
                    Background="#1E1E1E" Foreground="#D4D4D4"
                    ShowLineNumbers="True" Margin="0,5,0,0"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Auto"
                    SyntaxHighlighting="{Binding SyntaxSet}"/>

                <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch" Background="#333" Margin="0,2"/>

                <Grid Grid.Row="2" Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="{Binding [Lbl_Results], Source={x:Static local:LocalizationManager.Instance}}" Foreground="#888" FontSize="11" Margin="5,2"/>
                    <DataGrid Grid.Row="1" x:Name="QueryGrid" ItemsSource="{Binding GridItems}" HeadersVisibility="Column" AutoGenerateColumns="False" IsReadOnly="True"/>
                </Grid>
            </Grid>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" Background="#252526"/>

            <Grid Grid.Column="2" Background="#252526">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="{Binding [Lbl_Tables], Source={x:Static local:LocalizationManager.Instance}}" Foreground="#569CD6" FontWeight="Bold" Margin="10,10,10,5" FontSize="11"/>
                <ListBox Grid.Row="1" ItemsSource="{Binding TableNames}" SelectedItem="{Binding SelectedTableName}"
                         Background="Transparent" BorderThickness="0" Foreground="#CCC" Margin="5"/>

                <TextBlock Grid.Row="2" Text="{Binding [Lbl_Columns], Source={x:Static local:LocalizationManager.Instance}}" Foreground="#569CD6" FontWeight="Bold" Margin="10,10,10,5" FontSize="11"/>
                <DataGrid Grid.Row="3" ItemsSource="{Binding ColumnInfos}" HeadersVisibility="Column" AutoGenerateColumns="False" Margin="5" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{Binding [Col_ColumnName], Source={x:Static local:LocalizationManager.Instance}}" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="{Binding [Col_DataType], Source={x:Static local:LocalizationManager.Instance}}" Binding="{Binding DataType}" Width="Auto"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="4" Margin="10">
                    <Button Content="{Binding [Btn_ConnectDb], Source={x:Static local:LocalizationManager.Instance}}" ToolTip="{Binding [Btn_ConnectDb], Source={x:Static local:LocalizationManager.Instance}}" Style="{StaticResource ExecuteButtonStyle}" Background="#3E3E42" Margin="0,0,0,10" Command="{Binding ConnectDbCommand}"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding [Lbl_Language], Source={x:Static local:LocalizationManager.Instance}}" Foreground="#CCC" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox ItemsSource="{Binding LanguageItems}" SelectedItem="{Binding SelectedLanguage}" DisplayMemberPath="Display" Width="100"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>

        <StatusBar Grid.Row="2" Background="#007ACC" Foreground="White">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding [Lbl_Count], Source={x:Static local:LocalizationManager.Instance}}" Opacity="0.8"/>
                    <TextBlock Text="{Binding DataNum}" Margin="5,0,0,0"/>
                    <TextBlock Text="{Binding [Lbl_CountUnit], Source={x:Static local:LocalizationManager.Instance}}" Opacity="0.8" Margin="2,0,0,0"/>
                </StackPanel>
            </StatusBarItem>
            <Separator Background="#44FFFFFF"/>
            <StatusBarItem Content="{Binding SqlMessage}"/>
        </StatusBar>
    </Grid>
</Window>
